DATABASE_URL=sqlite+aiosqlite:///./aiclass.db
SECRET_KEY=change-me-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=["http://localhost:3000"]
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760

# ===== 视频脚本生成器 (即梦AI模板) =====
# 火山引擎ARK API Key — 在 https://console.volcengine.com/ark 创建
ARK_API_KEY=ark-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 文本生成模型ID — 需要先在火山方舟控制台开通
ARK_TEXT_MODEL=doubao-seed-2-0-pro-260215
# 语音识别模型ID
ARK_ASR_MODEL=bigmodel
# 视频脚本工具白名单（仅这些username可以用，逗号分隔）
VIDEO_SCRIPT_ALLOWED_USERS=admin
# 单次音频上传最大大小（MB）
MAX_AUDIO_SIZE_MB=10
